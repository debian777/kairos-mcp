{
  "name": "KAIROS MCP Development",

  "dockerComposeFile": [
    "../compose.yaml",
    "docker-compose.extend.yml"
  ],
  "service": "app-dev",
  "runServices": ["app-dev", "qdrant"],
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "forwardPorts": [3300, 9090],
  "portsAttributes": {
    "3300": { "label": "KAIROS MCP", "onAutoForward": "notify" },
    "9090": { "label": "Metrics", "onAutoForward": "silent" },
    "6333": { "label": "Qdrant", "onAutoForward": "silent" }
  },

  "containerEnv": {
    "NODE_ENV": "development"
  },

  "remoteUser": "kairos",

  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "enableNonRootDocker": "false"
    }
  },

  "onCreateCommand": "npm ci",
  "updateContentCommand": "npm run build",
  "postCreateCommand": {
    "install-deps": "npm ci",
    "build": "npm run build",
    "verify-env": "test -f .env || echo 'WARNING: Create .env from .env.dev_simple template'"
  },
  "postStartCommand": "echo 'KAIROS MCP dev container ready. Run: npm run dev:deploy'",
  "postAttachCommand": "echo 'Attach complete. Check status: npm run dev:status'",
  "waitFor": "postCreateCommand",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "ms-vscode.vscode-typescript-next",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  },

  "secrets": {
    "QDRANT_API_KEY": {
      "description": "Qdrant API key for vector database authentication",
      "documentationUrl": "https://qdrant.tech/documentation/guides/security/"
    },
    "OPENAI_API_KEY": {
      "description": "OpenAI API key for text embeddings (or use Ollama/TEI)",
      "documentationUrl": "https://platform.openai.com/docs/api-reference/authentication"
    }
  },

  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },

  "shutdownAction": "stopContainer",
  "overrideCommand": true
}
