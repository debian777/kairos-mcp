{
  "name": "KAIROS MCP Fullstack",

  "dockerComposeFile": [
    "../compose.yaml",
    "docker-compose-fullstack.extend.yml"
  ],
  "service": "app-dev",
  "runServices": ["app-dev", "qdrant", "valkey", "postgres", "keycloak"],
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "forwardPorts": [3300, 9090, 6379, 5432, 8080, 9000],
  "portsAttributes": {
    "3300": { "label": "KAIROS MCP", "onAutoForward": "notify" },
    "9090": { "label": "Metrics", "onAutoForward": "silent" },
    "6379": { "label": "Valkey", "onAutoForward": "silent" },
    "5432": { "label": "Postgres", "onAutoForward": "silent" },
    "8080": { "label": "Keycloak", "onAutoForward": "notify" },
    "9000": { "label": "Keycloak Health", "onAutoForward": "silent" }
  },

  "containerEnv": {
    "NODE_ENV": "development"
  },

  "remoteUser": "kairos",

  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "enableNonRootDocker": "false"
    }
  },

  "onCreateCommand": "npm ci",
  "updateContentCommand": "npm run build",
  "postCreateCommand": {
    "install-deps": "npm ci",
    "build": "npm run build",
    "verify-env": "test -f .env || echo 'WARNING: Create .env from .env.dev_simple template'",
    "wait-for-services": "sleep 10"
  },
  "postStartCommand": {
    "init-keycloak": "python3 scripts/deploy-configure-keycloak-realms.py || echo 'Keycloak init skipped (not first run)'",
    "status": "echo 'Fullstack ready. Run: npm run infra:up'"
  },
  "postAttachCommand": "echo 'Fullstack attached. Services: app, Qdrant, Valkey, Postgres, Keycloak'",
  "waitFor": "postCreateCommand",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "ms-vscode.vscode-typescript-next",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        }
      }
    }
  },

  "secrets": {
    "QDRANT_API_KEY": {
      "description": "Qdrant API key"
    },
    "OPENAI_API_KEY": {
      "description": "OpenAI API key for embeddings (or configure Ollama/TEI in .env)"
    },
    "KEYCLOAK_ADMIN_PASSWORD": {
      "description": "Keycloak admin password (auto-generated by deploy-generate-dev-secrets.py)"
    }
  },

  "hostRequirements": {
    "cpus": 6,
    "memory": "12gb",
    "storage": "40gb"
  },

  "shutdownAction": "stopContainer",
  "overrideCommand": true
}
