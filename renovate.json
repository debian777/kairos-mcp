{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate replaces Dependabot: npm, github-actions, Dockerfiles, docker-compose, Helm charts, and Helm values image tags. Disable Dependabot version updates in Settings \u2192 Code security and analysis. GitHub Dependabot vulnerability PRs already ignore global schedule; OSV is enabled for npm so more CVEs get fixes, also without schedule gating via packageRules.",
  "schedule": [
    "before 10am"
  ],
  "osvVulnerabilityAlerts": true,
  "openPullRequestsLimit": 10,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ],
    "prCreation": "immediate"
  },
  "helmv3": {
    "fileMatch": ["helm/kairos-mcp/Chart\\.yaml$"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Image tags in helm/kairos-mcp/values.yaml (split repository/tag pairs)",
      "fileMatch": ["helm/kairos-mcp/values\\.yaml$"],
      "matchStrings": [
        "repository:\\s*\"(?<depName>[^\"]+)\"\\s*\\n\\s*tag:\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Inline image references in helm/kairos-mcp/values.yaml (image: docker.io/org/name:tag)",
      "fileMatch": ["helm/kairos-mcp/values\\.yaml$"],
      "matchStrings": [
        "image:\\s*\"(?<depName>(?:docker\\.io|ghcr\\.io|quay\\.io)[^:]+):(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Group npm updates into one PR",
      "matchManagers": [
        "npm"
      ],
      "groupName": "npm",
      "commitMessagePrefix": "deps(npm)"
    },
    {
      "description": "Group GitHub Actions updates into one PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions",
      "commitMessagePrefix": "deps(actions)"
    },
    {
      "description": "Group Dockerfile image updates into one PR",
      "matchManagers": [
        "dockerfile"
      ],
      "groupName": "docker",
      "commitMessagePrefix": "deps(docker)"
    },
    {
      "description": "Group docker-compose image updates into one PR",
      "matchManagers": [
        "docker-compose"
      ],
      "groupName": "docker-compose",
      "commitMessagePrefix": "deps(compose)"
    },
    {
      "description": "Group Helm Chart.yaml dependency updates into one PR",
      "matchManagers": [
        "helmv3"
      ],
      "groupName": "helm",
      "commitMessagePrefix": "deps(helm)"
    },
    {
      "description": "Group Helm values image tag updates into one PR",
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        "helm/kairos-mcp/values.yaml"
      ],
      "groupName": "helm-images",
      "commitMessagePrefix": "deps(helm-images)"
    },
    {
      "description": "Exclude app image tag from Renovate (managed by stable release sync)",
      "matchManagers": [
        "custom.regex"
      ],
      "matchDepNames": [
        "quay.io/debian777/kairos-mcp"
      ],
      "enabled": false
    },
    {
      "description": "Pin Docker image digests for immutability and supply-chain compliance",
      "matchDatasources": [
        "docker"
      ],
      "pinDigests": true
    },
    {
      "description": "Security/vuln fixes: not gated by global schedule, own PR, immediate branch/PR creation (overrides bulk groups above)",
      "matchCategories": [
        "security"
      ],
      "schedule": [
        "at any time"
      ],
      "groupName": null,
      "prCreation": "immediate",
      "labels": [
        "security"
      ],
      "priorityScore": 10000
    },
    {
      "description": "Automerge patch/minor security fixes when CI is green (majors still open as PRs)",
      "matchCategories": [
        "security"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true
    }
  ]
}
