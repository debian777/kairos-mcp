AUTH_ENABLED=false

# Match simple-mode defaults to reuse the same local dependencies.
PORT=4300
METRICS_PORT=9490
QDRANT_URL=http://localhost:6333

# Keep simple-mode collection namespace for local integration parity.
QDRANT_COLLECTION=kairos_simple_ci

# Disable auth dependency wiring in stdio local mode.
KEYCLOAK_URL=
KEYCLOAK_INTERNAL_URL=
REDIS_URL=

# Opt-in local stdio transport.
TRANSPORT_TYPE=stdio
