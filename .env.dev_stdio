AUTH_ENABLED=false

# Match simple-mode defaults to reuse the same local dependencies.
METRICS_PORT=9490
QDRANT_URL=http://localhost:6333

# Keep simple-mode collection namespace in shared Qdrant.
QDRANT_COLLECTION=kairos_simple_ci

# Disable auth dependency wiring in stdio local mode.
KEYCLOAK_URL=
KEYCLOAK_INTERNAL_URL=
REDIS_URL=

# Local stdio transport: MCP only on stdin/stdout (no HTTP app; SERVER_PORT not used).
TRANSPORT_TYPE=stdio
