#!/bin/sh
# Disallow commits on main; use a branch and open a PR.
branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
if [ "$branch" = "main" ]; then
  echo ""
  echo "  Commits to main are not allowed. Use a branch and open a PR."
  echo "  Example: git checkout -b fix/my-change && git commit ..."
  echo ""
  exit 1
fi

# Linked worktrees / IDE races: drop index paths whose blob OID is missing from the
# object DB (otherwise `git commit` fails with "invalid object" / "Error building trees").
# Scan the full index, not only `git diff --cached`: IDE refresh during long ESLint can
# inject phantoms that are not part of the staged diff but still break write-tree.
drop_index_missing_blobs() {
  # Two-phase: never mutate the index while streaming ls-files. Use -z so paths are
  # NUL-delimited (newline-safe); line-based read can corrupt OIDs under sh -e / husky.
  # Parse blob OID with shell only (no awk â€” minimal PATH).
  tmp=$(mktemp) || exit 1
  git ls-files -z -s | while IFS= read -r -d '' line || [ -n "$line" ]; do
    case "$line" in
      *"	"*) ;;
      *) continue ;;
    esac
    meta=${line%%	*}
    path=${line#*	}
    rest=${meta#* }
    sha=${rest%% *}
    [ -n "$sha" ] && [ -n "$path" ] || continue
    # During `git commit`, GIT_OBJECT_DIRECTORY may point at a quarantine dir that only
    # holds new objects; cat-file would falsely report most blobs missing and strip the index.
    if ! ( unset GIT_OBJECT_DIRECTORY; git cat-file -e "$sha" 2>/dev/null ); then
      printf '%s\0' "$path" >>"$tmp"
    fi
  done
  if [ -s "$tmp" ]; then
    xargs -0 git rm --cached -f --ignore-unmatch -- <"$tmp" >/dev/null 2>&1 || true
  fi
  rm -f "$tmp"
}

# If blob checks fail broadly (broken ODB / worktree), do not leave a near-empty index â€”
# that would record a commit that deletes the whole tree.
assert_index_substantially_intact() {
  idx=$(git ls-files 2>/dev/null | wc -l | tr -d ' ')
  head_paths=$(git ls-tree -r HEAD --name-only 2>/dev/null | wc -l | tr -d ' ')
  [ "$head_paths" -lt 50 ] 2>/dev/null && return 0
  min_ok=$((head_paths * 85 / 100))
  if [ "$idx" -lt "$min_ok" ] 2>/dev/null; then
    echo >&2 ""
    echo >&2 "  ERROR: pre-commit index cleanup left too few paths ($idx vs ~$head_paths on HEAD)."
    echo >&2 "  Refusing commit. Try: git read-tree HEAD && re-stage, or fix the object database / worktree."
    echo >&2 ""
    exit 1
  fi
}

staged=$(git diff --cached --name-only)
# Version check: mem = package.json, skills = last stable (same as CI). Run when version-related files are staged.
if echo "$staged" | grep -q '^package\.json$' || echo "$staged" | grep -q '^skills/' || echo "$staged" | grep -q '^src/embed-docs/mem/'; then
  if ! npm run version:check-skills; then
    echo ""
    echo "  Tip: If 'last stable' looks wrong (e.g. 1.0.0), run: git fetch --tags"
    echo "  After a version bump, run: npm run version:sync-skills && git add skills/ src/embed-docs/mem/"
    echo ""
    exit 1
  fi
fi
# Skip heavy checks for version-bump commits (only package.json + package-lock.json).
# Real workflow: full build runs in dev:deploy and CI; version bumps need no build on commit.
count=$(echo "$staged" | wc -l | tr -d ' ')
if [ "$count" -eq 2 ]; then
  if echo "$staged" | grep -q '^package\.json$' && echo "$staged" | grep -q '^package-lock\.json$'; then
    exit 0
  fi
fi
# Skills (Agent Skills spec) are validated via `npm run lint` (includes lint:skills).
# Requires skills-ref for a strict check; see scripts/lint-agent-skills.py when optional.
#npm run build || exit 1
# Git: lint-related paths differ from HEAD (staged and/or unstaged). Informational only â€” does not block commit.
lint_git_paths=$(git diff --name-only HEAD -- eslint.config.cjs knip.config.ts eslint/ 2>/dev/null || true)
if [ -n "$lint_git_paths" ]; then
  echo >&2 ""
  echo >&2 "  ERROR (policy): Lint configuration changed vs last commit â€” review required"
  echo >&2 "  Files:"
  echo >&2 "$lint_git_paths" | sed 's/^/    - /' >&2
  echo >&2 ""
  echo >&2 "  AI / automation MUST:"
  echo >&2 "    - Fix the root cause (correct code, types, imports, dead exports, real rule updates)."
  echo >&2 "    - If the config itself is wrong, fix the rule or scope â€” not the symptom elsewhere."
  echo >&2 ""
  echo >&2 "  FORBIDDEN (hiding / bypass):"
  echo >&2 "    - Broad eslint ignore globs (e.g. **/*.ext) to silence one file."
  echo >&2 "    - eslint-disable / file-wide suppressions to avoid addressing the real issue."
  echo >&2 "    - Knip ignore* churn to hide unused code instead of removing or using it."
  echo >&2 "    - Checksum / fingerprint tricks that mask config drift."
  echo >&2 ""
  echo >&2 "  Pre-commit still allows this commit; humans must verify the diff."
  echo >&2 ""
fi
# Before lint: drop phantom index entries (IDE races). After lint: repeat in case
# ESLint window allowed new phantoms. cat-file checks must unset GIT_OBJECT_DIRECTORY
# (git sets it during commit quarantine; otherwise almost every blob looks missing).
drop_index_missing_blobs
assert_index_substantially_intact
# `git commit` exports GIT_INDEX_FILE (and related vars). lint:skills may run
# `pip install git+https://...`; nested git must not see those or it can rewrite
# this worktree's index. Parent shell keeps git's env for hook git commands.
( unset GIT_INDEX_FILE GIT_DIR GIT_PREFIX GIT_OBJECT_DIRECTORY || true
  npm run lint >&2
) || exit 1
drop_index_missing_blobs
assert_index_substantially_intact
