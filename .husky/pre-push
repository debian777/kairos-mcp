#!/bin/sh
while read -r _local_ref _local_sha remote_ref _remote_sha; do
  if echo "$remote_ref" | grep -q "^refs/tags/v"; then
    echo >&2 ""
    echo >&2 "  ERROR: Do not push release tags manually."
    echo >&2 ""
    echo >&2 "  This repo creates version tags after a version-bump PR merges to main."
    echo >&2 "  Use the version-bump workflow instead:"
    echo >&2 "    1. npm version <type> --no-git-tag-version"
    echo >&2 "       or npm run release:<type>"
    echo >&2 "    2. npm run version:sync-skills"
    echo >&2 "    3. Commit on release/<version> and open a PR to main"
    echo >&2 "    4. Merge the PR and let CI create the tag"
    echo >&2 ""
    exit 1
  fi
done
exit 0
