{
  "id": "kairos",
  "realm": "kairos",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "ssoSessionIdleTimeout": 604800,
  "ssoSessionMaxLifespan": 604800,
  "accessTokenLifespan": 28800,
  "accessCodeLifespan": 120,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "groups": [
    {
      "name": "shared",
      "subGroups": [
        { "name": "admin" },
        { "name": "auditor" },
        { "name": "operator" },
        { "name": "team-platform" },
        { "name": "team-sre" }
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "kairos-groups",
      "description": "Group membership claim — required for KAIROS space isolation",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "kairos-oidc-groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "true",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    },
    {
      "name": "openid",
      "description": "OpenID Connect scope — explicit scope for DCR policy compatibility",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "basic",
      "description": "OpenID Connect scope for basic claims — extended with groups mapper for DCR clients",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "auth_time",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usersessionmodel-note-mapper",
          "consentRequired": false,
          "config": {
            "user.session.note": "AUTH_TIME",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "auth_time",
            "jsonType.label": "long"
          }
        },
        {
          "name": "kairos-groups-always",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "true",
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "role_list",
    "saml_organization",
    "profile",
    "email",
    "roles",
    "web-origins",
    "acr",
    "basic",
    "kairos-groups",
    "openid"
  ],
  "defaultGroups": ["/shared/operator"],
  "clients": [
    {
      "clientId": "kairos-mcp",
      "name": "KAIROS MCP",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://127.0.0.1/auth/callback",
        "http://127.0.0.1/auth/continue-signin",
        "__KAIROS_PUBLIC_ORIGIN__/auth/callback",
        "__KAIROS_PUBLIC_ORIGIN__/auth/continue-signin"
      ],
      "webOrigins": [
        "http://127.0.0.1",
        "__KAIROS_PUBLIC_ORIGIN__"
      ],
      "defaultClientScopes": ["basic"],
      "attributes": {
        "post.logout.redirect.uris": "http://127.0.0.1/auth/continue-signin##__KAIROS_PUBLIC_ORIGIN__/auth/continue-signin",
        "logout.confirmation.enabled": "false"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "full.path": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    },
    {
      "clientId": "kairos-cli",
      "name": "KAIROS CLI / MCP host (public PKCE)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:*", "http://localhost:*/callback", "http://localhost:*/callback/*", "http://localhost:*/*", "http://127.0.0.1:*", "http://127.0.0.1:*/callback", "http://127.0.0.1:*/callback/*", "__KAIROS_PUBLIC_ORIGIN__/*"],
      "webOrigins": ["http://localhost", "__KAIROS_PUBLIC_ORIGIN__"],
      "defaultClientScopes": ["basic"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "full.path": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    }
  ],
  "components": {
    "org.keycloak.services.clientregistration.policy.ClientRegistrationPolicy": [
      {
        "name": "Allowed Client Scopes",
        "providerId": "allowed-client-templates",
        "subType": "anonymous",
        "config": {
          "allow-default-scopes": ["true"],
          "allowed-client-scopes": ["roles", "acr", "phone", "profile", "kairos-groups", "offline_access", "address", "basic", "email", "openid", "web-origins"]
        }
      },
      {
        "name": "Allowed Client Scopes",
        "providerId": "allowed-client-templates",
        "subType": "authenticated",
        "config": {
          "allow-default-scopes": ["true"]
        }
      }
    ]
  }
}
