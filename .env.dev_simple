AUTH_ENABLED=false

# Isolated app/metrics ports for simple mode.
SERVER_PORT=4300
METRICS_PORT=9490
QDRANT_URL=http://localhost:6333

# Isolated data namespace in shared Qdrant.
QDRANT_COLLECTION=kairos_simple_ci

# Disable auth dependency wiring in simple mode.
KEYCLOAK_URL=
KEYCLOAK_INTERNAL_URL=
REDIS_URL=
TRANSPORT_TYPE=http
