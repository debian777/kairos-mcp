AUTH_ENABLED=false

# Isolated app/metrics ports for simple mode.
SERVER_PORT=4300
METRICS_PORT=9490
QDRANT_URL=http://localhost:7633

# Unified collection name for all CI/test workflows.
# Local dev and CI both use kairos_ci for predictability.
QDRANT_COLLECTION=kairos_ci

# Disable auth dependency wiring in simple mode.
KEYCLOAK_URL=
KEYCLOAK_INTERNAL_URL=
REDIS_URL=
KEY_VALUE_STORE_URL=
TRANSPORT_TYPE=http
