# Fullstack: infra + app + auth. Used by scripts/deploy-generate-dev-secrets.py to produce .env (same keys as CI integration job).
# Keycloak realms: scripts/keycloak/import/*.json + python3 scripts/deploy-configure-keycloak-realms.py (optional vars in scripts/env/env.rc).
KEYCLOAK_ADMIN_PASSWORD=__KEYCLOAK_ADMIN_PASSWORD__
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_DB_PASSWORD=__KEYCLOAK_DB_PASSWORD__
REDIS_PASSWORD=__REDIS_PASSWORD__
QDRANT_API_KEY=__QDRANT_API_KEY__
QDRANT_COLLECTION=kairos_dev
QDRANT_URL=http://127.0.0.1:6333
REDIS_URL=redis://:__REDIS_PASSWORD__@127.0.0.1:6379
# Main HTTP listener: UI, REST API, and Streamable HTTP MCP (when transport is http or stdio side channel).
SERVER_PORT=3300
METRICS_PORT=9390
# Optional: absolute path (or cwd-relative) to the Vite output directory (dist/ui). Use when the server serves an unexpected UI tree.
# KAIROS_UI_DIR=
# Concurrency limit for MCP POST /mcp; 0=auto-detect, -1=disabled. High dev default avoids integration-test stalls; use a low value (e.g. 10) for load/concurrency tests (tests/load, npm run test:load).
MAX_CONCURRENT_MCP_REQUESTS=10000
# When true, MCP App chat widgets skip ui/initialize and ignore tool results (static shell for host debugging).
# KAIROS_MCP_WIDGET_PRESENTATION_ONLY=false
NODE_ENV=development
LOG_LEVEL=info
LOG_FORMAT=json
KAIROS_REDIS_PREFIX=kairos:dev:
OPENAI_API_KEY=__OPENAI_API_KEY__
# OPENAI_EMBEDDING_MODEL and OPENAI_API_URL have app defaults; set to override.
EMBEDDING_PROVIDER=openai
QDRANT_RESCORE=true
QDRANT_SNAPSHOT_DIR=var/snapshots
AUTH_ENABLED=true
SESSION_SECRET=__SESSION_SECRET__
SESSION_MAX_AGE_SEC=604800
AUTH_CALLBACK_BASE_URL=http://localhost:3300
# Optional: expand kairos-mcp redirect URIs for every port from MIN through MAX (localhost + 127.0.0.1). Defaults match 3300–3301. Run: python3 scripts/deploy-configure-keycloak-realms.py
# KAIROS_DEV_APP_PORT_MIN=3300
# KAIROS_DEV_APP_PORT_MAX=3301
# For E2E and CLI browser login, KEYCLOAK_URL must be a URL the browser can open (e.g. http://localhost:8080). deploy-run-env.sh overrides keycloak:8080 to localhost:8080 when starting the dev server.
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=kairos-dev
KEYCLOAK_CLIENT_ID=kairos-mcp
KEYCLOAK_CLI_CLIENT_ID=kairos-cli
# Only set when the app runs inside Docker (so it can reach Keycloak by hostname). Leave unset when app runs on host (e.g. npm run dev:start).
# KEYCLOAK_INTERNAL_URL=http://keycloak:8080
AUTH_MODE=oidc_bearer
AUTH_TRUSTED_ISSUERS=http://localhost:8080/realms/kairos-dev
# Include both so server (kairos-mcp) and CLI (kairos-cli) tokens are accepted
AUTH_ALLOWED_AUDIENCES=kairos-mcp,kairos-cli
# Optional: intersect JWT `groups` with this list (comma-separated full paths).
# Use trailing `/` for path-prefix matching (for example, /shared/).
# Empty or unset = all JWT group paths are accepted as spaces (no filtering). Set entries to restrict.
# OIDC_GROUPS_ALLOWLIST=/kairos-auditor,/shared/
# Optional: example group path in MCP tool descriptions (activate, spaces, train, tune).
# Default: derived from the first path-prefix entry in OIDC_GROUPS_ALLOWLIST plus
# KAIROS_GROUP_SPACE_EXAMPLE_SUFFIX (default pe-team), e.g. /shared/ → /shared/pe-team.
# KAIROS_GROUP_SPACE_PATH_EXAMPLE=/shared/pe-team
# KAIROS_GROUP_SPACE_EXAMPLE_SUFFIX=pe-team
# Optional: second Keycloak user (dev) used only for /shared/ci-test — provisioned by scripts/deploy-configure-keycloak-realms.py
# KAIROS_CI_TEST_USERNAME=kairos-ci-tester
# KAIROS_CI_TEST_PASSWORD=kairos-ci-tester-secret
# Optional: for scripts/deploy-configure-keycloak-google-idp.py (Google IdP in kairos-dev)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
