{
  "id": "kairos-prod",
  "realm": "kairos-prod",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "ssoSessionIdleTimeout": 604800,
  "ssoSessionMaxLifespan": 604800,
  "accessTokenLifespan": 3600,
  "groups": [
    { "name": "kairos-admin" },
    { "name": "kairos-auditor" },
    { "name": "shared" },
    {
      "name": "kairos-shares",
      "subGroups": [{ "name": "kairos-operator" }]
    },
    { "name": "kairos-team-platform" },
    { "name": "kairos-team-sre" }
  ],
  "clients": [
    {
      "clientId": "kairos-mcp",
      "name": "KAIROS MCP (prod)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/auth/callback",
        "http://127.0.0.1:3000/auth/callback"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000"
      ]
    },
    {
      "clientId": "kairos-cli",
      "name": "KAIROS CLI / MCP host (public PKCE)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:*", "http://localhost:*/callback", "http://localhost:*/callback/*", "http://localhost:*/*"],
      "webOrigins": ["http://localhost"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ]
}
