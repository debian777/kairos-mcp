{
  "id": "kairos-dev",
  "realm": "kairos-dev",
  "enabled": true,
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "ssoSessionIdleTimeout": 604800,
  "ssoSessionMaxLifespan": 604800,
  "accessTokenLifespan": 3600,
  "accessCodeLifespan": 120,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "groups": [
    { "name": "kairos-team-platform" },
    { "name": "kairos-team-sre" }
  ],
  "clients": [
    {
      "clientId": "kairos-mcp",
      "name": "KAIROS MCP (dev)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"]
    },
    {
      "clientId": "kairos-cli",
      "name": "KAIROS CLI / MCP host (public PKCE)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:*", "http://localhost:*/callback", "http://localhost:*/callback/*", "http://localhost:*/*", "http://127.0.0.1:*", "http://127.0.0.1:*/callback", "http://127.0.0.1:*/callback/*"],
      "webOrigins": ["http://localhost"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ]
}
