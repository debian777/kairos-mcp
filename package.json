{
  "name": "@debian777/kairos-mcp",
  "version": "3.1.0-pre.3",
  "description": "kairos MCP Server - AI Knowledge Memory System for AI Agent Consciousness Infrastructure",
  "type": "module",
  "main": "dist/index.js",
  "author": "Jakub Plichcinski <kuba@xpl.pl>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/debian777/kairos-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/debian777/kairos-mcp/issues"
  },
  "homepage": "https://github.com/debian777/kairos-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "knowledge-bank",
    "ai-knowledge",
    "ai-memory",
    "knowledge-management",
    "ai-consciousness",
    "ai-infrastructure",
    "vector-database",
    "qdrant",
    "ai-agents",
    "knowledge-retrieval",
    "semantic-search"
  ],
  "bin": {
    "kairos": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "npm run dev:deploy && npm run dev:test",
    "dev:build": "npm run lint && npm run knip && npm run ui:build && ENV=dev ./scripts/run-env.sh build",
    "dev:deploy": "npm run dev:build && npm run dev:restart",
    "dev:logs": "ENV=dev ./scripts/run-env.sh logs",
    "dev:qdrant-curl": "ENV=dev ./scripts/run-env.sh qdrant-curl",
    "dev:redis-cli": "ENV=dev ./scripts/run-env.sh redis-cli",
    "dev:restart": "ENV=dev ./scripts/run-env.sh restart",
    "dev:start": "ENV=dev ./scripts/run-env.sh start",
    "dev:start:installed": "DOTENV_CONFIG_PATH=.env PORT=3300 node -r dotenv/config node_modules/@debian777/kairos-mcp/dist/index.js",
    "dev:status": "ENV=dev ./scripts/run-env.sh status",
    "dev:stop": "ENV=dev ./scripts/run-env.sh stop",
    "dev:test": "ENV=dev ./scripts/run-env.sh test",
    "test:load": "ENV=dev ./scripts/run-env.sh test -- tests/load/mcp-concurrency-limit.test.ts",
    "dev:test-embedding-key": "node scripts/test-embedding-key.mjs",
    "dev:google-idp": "python3 scripts/configure-keycloak-google-idp.py",
    "dev:ai-mcp-integration": "node scripts/run-ai-mcp-integration.mjs",
    "prod:health": "ENV=prod ./scripts/run-env.sh health",
    "prod:status": "ENV=prod ./scripts/run-env.sh status",
    "prod:qdrant-curl": "ENV=prod ./scripts/run-env.sh qdrant-curl",
    "prod:raw-qdrant-search": "node -r dotenv/config scripts/raw-qdrant-search.mjs",
    "query-scoring": "node -r dotenv/config scripts/run-query-scoring.mjs",
    "backfill:attest-boost": "node -r dotenv/config scripts/backfill-attest-boost.mjs",
    "query-search": "node -r dotenv/config scripts/query-search-standalone.mjs",
    "prod:redis-cli": "ENV=prod ./scripts/run-env.sh redis-cli",
    "prod:logs": "ENV=prod ./scripts/run-env.sh logs",
    "build": "npm run prebuild && node -e \"if(!process.env.DOCKER_BUILD){const r=require('child_process').spawnSync('npm',['run','lint'],{stdio:'inherit'});if(r.status!==0)process.exit(r.status!=null?r.status:1)}\" && npm run ui:build && npx tsc && chmod +x dist/cli/index.js",
    "docker:build": "docker build --build-arg PACKAGE_VERSION=$(node -p \"require('./package.json').version\") -t debian777/kairos-mcp:latest -t debian777/kairos-mcp:$(node -p \"require('./package.json').version\") .",
    "docker:build:dev": "docker build -f Dockerfile.dev -t debian777/kairos-mcp:dev .",
    "docker:push": "docker push debian777/kairos-mcp:latest && docker push debian777/kairos-mcp:$(node -p \"require('./package.json').version\")",
    "docker:publish": "npm run docker:build && npm run docker:push",
    "ui:dev": "vite",
    "ui:build": "vite build",
    "ui:preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "design:viewports": "node scripts/capture-viewports.mjs",
    "test:ui": "NODE_OPTIONS='--no-webstorage' vitest run --config vitest.config.ts",
    "test:ui:watch": "NODE_OPTIONS='--no-webstorage' vitest --config vitest.config.ts",
    "pack": "npm run build && npm pack",
    "npm:publish": "npm run build && npm publish --access public",
    "npm:publish:dry": "npm run build && npm publish --access public --dry-run",
    "ensure-coding-rules": "./scripts/run-env.sh ensure-coding-rules",
    "knip": "node -e \"if(process.env.DOCKER_BUILD)process.exit(0); const r=require('child_process').spawnSync('npx',['knip','--no-config-hints'],{stdio:'inherit'});process.exit(r.status!=null?r.status:1)\"",
    "handoff": "npm run dev:deploy && npm run dev:test && npm run ensure-coding-rules && npm run knip",
    "infra:up": "docker compose -p kairos-mcp --env-file .env --profile fullstack up -d --remove-orphans && python3 scripts/configure-keycloak-realms.py",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs,.cjs --fix",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx,.mjs,.cjs",
    "lint:skills": "python3 scripts/lint_skills.py",
    "version:sync-skills": "node scripts/sync-skill-versions.mjs",
    "version:check-skills": "node scripts/sync-skill-versions.mjs --check",
    "prebuild": "npm ci && npm run verify:clean && npx ts-node scripts/embed-docs.ts && node scripts/sync-skill-versions.mjs",
    "verify:clean": "node scripts/verify-clean-source.mjs",
    "prepare": "husky",
    "build:tgz": "node scripts/ensure-tgz.mjs",
    "test:tgz": "node scripts/test-tgz-install.mjs",
    "prepare:publish": "npm run build:tgz && npm run test:tgz",
    "publish": "npm run prepare:publish && npm publish ./dist/debian777-kairos-mcp-$(node -p \"require('./package.json').version\").tgz --access public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@tanstack/react-query": "^5.62.0",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/markdown": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "i18next": "^24.2.0",
    "jose": "^6.1.3",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "raw-body": "^3.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.4.0",
    "redis": "^5.11.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/test-sequencer": "^30.2.0",
    "@storybook/addon-docs": "10.3.0-alpha.17",
    "@storybook/react": "10.3.0-alpha.17",
    "@storybook/react-vite": "10.3.0-alpha.17",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-storybook": "10.3.0-alpha.17",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jsdom": "^25.0.0",
    "knip": "^5.85.0",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.49.0",
    "storybook": "10.3.0-alpha.17",
    "tailwindcss": "^4.0.0",
    "testcontainers": "^11.12.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "undici": "^7.22.0",
    "vite": "^8.0.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "overrides": {
    "@joshwooding/vite-plugin-react-docgen-typescript": {
      "vite": "$vite"
    },
    "glob": "^13.0.0",
    "minimatch": "^10.2.1"
  }
}
