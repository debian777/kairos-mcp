{
  "name": "@debian777/kairos-mcp",
  "version": "4.2.1",
  "description": "MCP server for agent automation: persistent memory and deterministic workflow execution for AI agents and chats",
  "type": "module",
  "main": "dist/index.js",
  "author": "Jakub Plichcinski <kuba@xpl.pl>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/debian777/kairos-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/debian777/kairos-mcp/issues"
  },
  "homepage": "https://github.com/debian777/kairos-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent-automation",
    "workflow-orchestration",
    "ai-agents",
    "ai-memory",
    "knowledge-management",
    "vector-database",
    "qdrant",
    "semantic-search",
    "ai-infrastructure"
  ],
  "bin": {
    "kairos": "dist/cli/index.js",
    "kairos-mcp": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "cli": "node dist/cli/index.js",
    "cli:dev": "sh -c 'set -a && [ -f .env ] && . ./.env; set +a && export KAIROS_API_URL=\"${KAIROS_API_URL:-http://localhost:${SERVER_PORT:-3300}}\" && exec node dist/cli/index.js \"$@\"' _",
    "dev:cli-ready": "./scripts/deploy-dev-cli-ready.sh",
    "test": "npm run dev:deploy && npm run dev:test",
    "dev:build": "npm run lint && npm run knip && npm run ui:build && ENV=dev ./scripts/deploy-run-env.sh build",
    "dev:deploy": "npm run dev:build && npm run dev:restart",
    "dev:logs": "ENV=dev ./scripts/deploy-run-env.sh logs",
    "dev:qdrant-curl": "ENV=dev ./scripts/deploy-run-env.sh qdrant-curl",
    "dev:redis-cli": "ENV=dev ./scripts/deploy-run-env.sh redis-cli",
    "dev:restart": "ENV=dev ./scripts/deploy-run-env.sh restart",
    "dev:start": "ENV=dev ./scripts/deploy-run-env.sh start",
    "dev:start:installed": "DOTENV_CONFIG_PATH=.env node -r dotenv/config node_modules/@debian777/kairos-mcp/dist/index.js",
    "dev:status": "ENV=dev ./scripts/deploy-run-env.sh status",
    "dev:stop": "ENV=dev ./scripts/deploy-run-env.sh stop",
    "dev:test": "ENV=dev ./scripts/deploy-run-env.sh test",
    "dev:stdio": "sh -c 'set -a && [ -f .env ] && . ./.env; [ -f .env.dev_stdio ] && . ./.env.dev_stdio; set +a; exec node dist/bootstrap.js'",
    "dev_simple:deploy": "npm run dev:build && npm run dev_simple:restart",
    "dev_simple:logs": "ENV=dev_simple ./scripts/deploy-run-env.sh logs",
    "dev_simple:qdrant-curl": "ENV=dev_simple ./scripts/deploy-run-env.sh qdrant-curl",
    "dev_simple:restart": "ENV=dev_simple ./scripts/deploy-run-env.sh restart",
    "dev_simple:start": "ENV=dev_simple ./scripts/deploy-run-env.sh start",
    "dev_simple:status": "ENV=dev_simple ./scripts/deploy-run-env.sh status",
    "dev_simple:stop": "ENV=dev_simple ./scripts/deploy-run-env.sh stop",
    "dev_simple:test": "ENV=dev_simple ./scripts/deploy-run-env.sh test",
    "dev_stdio:deploy": "npm run dev:build && npm run dev_stdio:restart",
    "dev_stdio:logs": "ENV=dev_stdio ./scripts/deploy-run-env.sh logs",
    "dev_stdio:qdrant-curl": "ENV=dev_stdio ./scripts/deploy-run-env.sh qdrant-curl",
    "dev_stdio:restart": "ENV=dev_stdio ./scripts/deploy-run-env.sh restart",
    "dev_stdio:start": "ENV=dev_stdio ./scripts/deploy-run-env.sh start",
    "dev_stdio:status": "ENV=dev_stdio ./scripts/deploy-run-env.sh status",
    "dev_stdio:stop": "ENV=dev_stdio ./scripts/deploy-run-env.sh stop",
    "dev_stdio:test": "ENV=dev_stdio ./scripts/deploy-run-env.sh test",
    "test:integration:contracts:http-auth": "ENV=dev ./scripts/deploy-run-env.sh test -- tests/integration/scenarios/spaces-tool.http-auth.test.ts",
    "test:integration:contracts:http-simple": "ENV=dev_simple ./scripts/deploy-run-env.sh test -- tests/integration/scenarios/spaces-tool.http-simple.test.ts",
    "test:integration:contracts:stdio-simple": "ENV=dev_stdio ./scripts/deploy-run-env.sh test -- tests/integration/scenarios/spaces-tool.stdio-simple.test.ts",
    "test:load": "ENV=dev ./scripts/deploy-run-env.sh test -- tests/load/mcp-concurrency-limit.test.ts",
    "dev:test-embedding-key": "node scripts/test-embedding-key.mjs",
    "dev:google-idp": "python3 scripts/deploy-configure-keycloak-google-idp.py",
    "dev:ai-mcp-integration": "node scripts/test-ai-mcp-integration.mjs",
    "prod:health": "ENV=prod ./scripts/deploy-run-env.sh health",
    "prod:status": "ENV=prod ./scripts/deploy-run-env.sh status",
    "prod:qdrant-curl": "ENV=prod ./scripts/deploy-run-env.sh qdrant-curl",
    "prod:raw-qdrant-search": "node -r dotenv/config scripts/deploy-raw-qdrant-search.mjs",
    "prod:redis-cli": "ENV=prod ./scripts/deploy-run-env.sh redis-cli",
    "prod:logs": "ENV=prod ./scripts/deploy-run-env.sh logs",
    "build": "npm run prebuild && node -e \"if(!process.env.DOCKER_BUILD){const r=require('child_process').spawnSync('npm',['run','lint'],{stdio:'inherit'});if(r.status!==0)process.exit(r.status!=null?r.status:1)}\" && npm run ui:build && npx tsc && chmod +x dist/cli/index.js",
    "docker:build": "docker build --target runtime --build-arg PACKAGE_VERSION=$(node -p \"require('./package.json').version\") -t debian777/kairos-mcp:latest -t debian777/kairos-mcp:$(node -p \"require('./package.json').version\") .",
    "docker:build:dev": "docker build -f Dockerfile.dev -t debian777/kairos-mcp:dev .",
    "docker:push": "docker push debian777/kairos-mcp:latest && docker push debian777/kairos-mcp:$(node -p \"require('./package.json').version\")",
    "docker:publish": "npm run docker:build && npm run docker:push",
    "ui:build": "vite build",
    "design:viewports": "node scripts/test-capture-viewports.mjs",
    "test:ui": "NODE_OPTIONS='--no-webstorage' vitest run --config vitest.config.ts",
    "test:ui:watch": "NODE_OPTIONS='--no-webstorage' vitest --config vitest.config.ts",
    "test:helm": "./scripts/test-helm.sh",
    "pack": "npm run build && npm pack",
    "npm:publish": "npm run build && npm publish --access public",
    "npm:publish:dry": "npm run build && npm publish --access public --dry-run",
    "ensure-coding-rules": "./scripts/deploy-run-env.sh ensure-coding-rules",
    "knip": "node -e \"if(process.env.DOCKER_BUILD)process.exit(0); const r=require('child_process').spawnSync('npx',['knip','--no-config-hints'],{stdio:'inherit'});process.exit(r.status!=null?r.status:1)\"",
    "handoff": "npm run dev:deploy && npm run dev:test && npm run ensure-coding-rules && npm run knip",
    "infra:up": "docker compose -p kairos-mcp --env-file .env --profile fullstack up -d --remove-orphans && python3 scripts/deploy-configure-keycloak-realms.py",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs,.cjs --fix",
    "lint": "eslint . && npm run lint:skills",
    "lint:skills": "python3 scripts/lint-agent-skills.py",
    "skills:sync-install-refs": "python3 scripts/sync-kairos-install-references.py",
    "compose:sync-app-tag": "node -e \"const fs=require('fs');const p='compose.yaml';const v=require('./package.json').version;let s=fs.readFileSync(p,'utf8');s=s.replace(/(^\\s*image:\\s*debian777\\/kairos-mcp:)(\\S+)/m,(_,prefix)=>prefix+'v'+v);fs.writeFileSync(p,s);\"",
    "version:sync": "npm run version:sync-skills && npm run compose:sync-app-tag",
    "version:sync-skills": "node scripts/build-sync-skill-versions.mjs",
    "version:check-skills": "node scripts/build-sync-skill-versions.mjs --check",
    "prebuild": "npm run verify:clean && npm run skills:sync-install-refs && npx ts-node scripts/build-embed-docs.ts && node scripts/build-sync-skill-versions.mjs",
    "verify:clean": "node scripts/lint-verify-clean-source.mjs",
    "prepare": "husky",
    "build:tgz": "node scripts/build-ensure-tgz.mjs",
    "test:tgz": "node scripts/ci-test-tgz-install.mjs",
    "test:package-local": "npm run build:tgz && npm run test:tgz",
    "prepare:publish": "npm run build:tgz && npm run test:tgz",
    "publish": "npm run prepare:publish && npm publish ./dist/debian777-kairos-mcp-$(node -p \"require('./package.json').version\").tgz --access public",
    "release:major": "npm version major --no-git-tag-version && npm run version:sync",
    "release:minor": "npm version minor --no-git-tag-version && npm run version:sync",
    "release:patch": "npm version patch --no-git-tag-version && npm run version:sync",
    "release:bug": "npm run release:patch",
    "release:rc": "npm version prerelease --preid=rc --no-git-tag-version && npm run version:sync",
    "release:pre": "npm version prerelease --preid=pre --no-git-tag-version && npm run version:sync",
    "release:beta": "npm version prerelease --preid=beta --no-git-tag-version && npm run version:sync"
  },
  "dependencies": {
    "@exodus/bytes": "^1.15.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@napi-rs/keyring": "^1.2.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@tanstack/react-query": "^5.62.0",
    "@tiptap/core": "^3.20.2",
    "@tiptap/extension-link": "^3.20.2",
    "@tiptap/extension-table": "^3.20.1",
    "@tiptap/markdown": "^3.20.2",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "i18next": "^26.0.2",
    "jose": "^6.1.3",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "raw-body": "^3.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.4.0",
    "redis": "^5.11.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@jest/test-sequencer": "^30.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jsdom": "^29.0.0",
    "knip": "^6.0.0",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.49.0",
    "tailwindcss": "^4.0.0",
    "testcontainers": "^11.12.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "undici": "^8.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "overrides": {
    "path-to-regexp": "^8.4.0",
    "glob": "^13.0.0",
    "minimatch": "^10.2.3",
    "tar": "^7.5.11"
  }
}
